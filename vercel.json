{
  "routes": [
    {
      "src": "^https://toutfeutoutflamme.eu/(.*)",
      "status": 301,
      "headers": {
        "Location": "https://www.toutfeutoutflamme.eu/$1"
      }
    },
    {
      "src": "/google(.*).html",
      "dest": "/google$1.html"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
