{
  "redirects": [
    {
      "source": "/ville/:slug",
      "destination": "/entretien-poele-granules/:slug",
      "permanent": true
    }
  ],

  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
      
    },
        {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/google30cd4d5b8be8c040.html",
      "destination": "/google30cd4d5b8be8c040.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"

      
    }
  ]
}
